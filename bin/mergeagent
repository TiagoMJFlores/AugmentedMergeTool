#!/bin/bash
# Resolve symlinks to find the real install directory
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

# Use packaged app if available, otherwise npx electron
APP="$DIR/release/mac-arm64/AugmentedMergeTool.app/Contents/MacOS/AugmentedMergeTool"
if [ -x "$APP" ]; then
  "$APP" "$@"
else
  npx electron "$DIR/dist/adapters/gui/main.js" "$@"
fi
