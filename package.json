{
  "name": "augmented-merge-tool",
  "version": "1.0.0",
  "description": "Essentialist AI merge conflict resolver — detects conflicts, extracts ticket intent from commit messages, resolves with Claude.",
  "main": "dist/index.js",
  "bin": {
    "mergeagent": "dist/index.js",
    "mergeagent-gui": "dist/adapters/gui/main.js"
  },
  "scripts": {
    "build": "tsc && npm run copy:gui-assets",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "copy:gui-assets": "node -e \"const fs=require('fs');fs.mkdirSync('dist/adapters/gui/renderer',{recursive:true});fs.copyFileSync('src/adapters/gui/renderer/index.html','dist/adapters/gui/renderer/index.html');fs.copyFileSync('src/adapters/gui/renderer/styles.css','dist/adapters/gui/renderer/styles.css');\"",
    "start:gui": "npm run build && electron dist/adapters/gui/main.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TiagoMJFlores/AugmentedMergeTool.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/TiagoMJFlores/AugmentedMergeTool/issues"
  },
  "homepage": "https://github.com/TiagoMJFlores/AugmentedMergeTool#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@linear/sdk": "^80.0.0",
    "dotenv": "^17.3.1",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
